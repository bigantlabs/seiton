{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 1
    },
    "items": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "const": "delete_item"
              },
              "itemId": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "itemId"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "const": "assign_folder"
              },
              "itemId": {
                "type": "string",
                "minLength": 1
              },
              "folderId": {
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "folderName": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "kind",
              "itemId",
              "folderId",
              "folderName"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string",
                "const": "create_folder"
              },
              "folderName": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "kind",
              "folderName"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "savedAt": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "items",
    "savedAt"
  ],
  "additionalProperties": false
}
