{
  "name": "seiton",
  "version": "0.3.0",
  "description": "Interactive command-line auditor for Bitwarden vaults",
  "type": "module",
  "license": "MIT",
  "bin": {
    "seiton": "./dist/bw-organize.js"
  },
  "files": [
    "dist/",
    "schemas/",
    "man/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test 'test/unit/**/*.test.ts' 'test/*.test.ts'",
    "test:unit": "node --import tsx --test 'test/unit/**/*.test.ts'",
    "test:integration": "node --import tsx --test 'test/integration/**/*.test.ts'",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-exclude='test/**' --import tsx --test 'test/unit/**/*.test.ts'",
    "gen:docs": "node --import tsx scripts/gen-schemas.ts && node --import tsx scripts/gen-help-docs.ts && node --import tsx scripts/gen-man.ts",
    "lint:layering": "node --import tsx scripts/check-layering.ts",
    "check:stability": "node --import tsx scripts/check-stability.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "fastest-levenshtein": "^1.0.16",
    "tldts": "^7.0.28",
    "zod": "^4.3.6",
    "zxcvbn-ts": "^2.0.2"
  }
}
